[user]
	email = 39796883+JeffreyTheTukkr@users.noreply.github.com
	name = Jeffrey
	signingkey = /Users/jeffrey/.ssh/id_ed25519.pub

[push]
	autoSetupRemote = true

[commit]
	gpgsign = false

[gpg]
	format = ssh

[core]
    pager = delta

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true
     line-numbers = true
      hunk-header-decoration-style = none
      hunk-header-style = file line-number syntax

[merge]
    conflictStyle = zdiff3

